# Required for fetching live SPY data (fetch_massive.py, analyst server)
MASSIVE_API_KEY=your_massive_api_key_here

# Required for the analyst server (analyst/server.py)
ANALYST_API_SECRET=your_shared_secret_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional overrides
# SPY_DB_PATH=/path/to/spy.db
# KNOWLEDGE_PATH=/path/to/KNOWLEDGE.md
# STUDIES_PATH=/path/to/analyst/studies_reference.md
